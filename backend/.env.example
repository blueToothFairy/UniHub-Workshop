PORT=3000
JWT_SECRET=replace_me
JWT_ACCESS_TTL_MINUTES=15

# Upstash Redis / BullMQ
REDIS_URL=rediss://:<password>@<host>:<port>
REDIS_TOKEN=replace_me
USE_REDIS=false
PAYMENT_CIRCUIT_FAILURE_THRESHOLD=5
PAYMENT_CIRCUIT_FAILURE_WINDOW_SECONDS=30
PAYMENT_CIRCUIT_OPEN_DURATION_SECONDS=60
PAYMENT_CIRCUIT_HALF_OPEN_PROBE_LIMIT=1

# Supabase
SUPABASE_POOLER_URL=postgres://user:password@host:6543/db
SUPABASE_DIRECT_URL=postgres://user:password@host:5432/db

# Cloudflare R2 (S3-compatible)
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=replace_me
CLOUDFLARE_R2_SECRET_KEY=replace_me
CLOUDFLARE_R2_BUCKET=unihub
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://<account-id>.r2.cloudflarestorage.com

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# Gemini API (for PDF processing)
GEMINI_API_KEY=replace_me
MOMO_CREATE_ORDER_TIMEOUT_MS=10000
MOMO_QUERY_TIMEOUT_MS=10000

# Resend Email (for notification channel)
RESEND_API_KEY=replace_me
NOTIFICATION_EMAIL_FROM=onboarding@resend.dev
