{
  "name": "unihub-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "migrate:run": "tsx scripts/run_migration_and_check.ts",
    "test:csv-import:migration": "node scripts/test_csv_import_migration_constraints.mjs",
    "test:csv-import:service": "node scripts/test_csv_import_service.mjs",
    "test:csv-import:cron": "node scripts/test_csv_import_cron.mjs",
    "demo:csv-import:evening:prepare": "node scripts/demo_evening_csv_import.mjs --prepare",
    "demo:csv-import:evening": "node scripts/demo_evening_csv_import.mjs",
    "smoke:local": "tsx scripts/smoke_local_flow.ts",
    "search:rebuild": "tsx scripts/rebuild_workshop_search_index.ts",
    "test:workshop:map": "tsx scripts/test_workshop_mapping.ts",
    "test:workshop:integration": "tsx scripts/test_integration_workshop_read.ts",
    "test:workshop:discovery": "tsx scripts/test_workshop_discovery_backend.ts && tsx scripts/test_workshop_search_index.ts",
    "test:frontend:workshop-discovery": "tsx scripts/test_frontend_workshop_discovery.ts",
    "test:payment:contracts": "tsx scripts/test_payment_callback_integration.ts",
    "test:payment:contention": "tsx scripts/test_paid_flow_contention.ts",
    "test:payment:circuit-breaker": "tsx scripts/test_payment_circuit_breaker_integration.ts",
    "test:checkin:reads": "tsx scripts/test_checkin_reads.ts",
    "test:peak:rehearsal": "tsx scripts/test_peak_controller_rehearsal.ts",
    "test:peak:e2e": "tsx scripts/test_peak_controller_e2e.ts",
    "test:peak:scale": "tsx scripts/test_peak_controller_scale_e2e.ts",
    "test:notification:unit": "tsx --test src/modules/notification/notification.service.test.ts",
    "test:notification:integration": "tsx --test src/modules/notification/notification.router.test.ts src/modules/registration/registration.notification-enqueue.test.ts",
    "test:notification:worker": "tsx --test src/modules/notification/notification.service.test.ts",
    "test:admin:audit-log-paging": "tsx --test src/modules/admin/admin-audit-log-cursor.test.ts src/modules/admin/admin.service.audit-log.test.ts src/modules/admin/admin.router.audit-log.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@google/generative-ai": "^0.24.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.76.5",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.1.4",
    "express": "^4.19.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
